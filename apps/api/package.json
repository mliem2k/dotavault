{
  "name": "api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/cron": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.15",
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  }
}
