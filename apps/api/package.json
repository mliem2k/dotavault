    "drizzle-orm": "^0.45.0",
    "elysia": "^1.4.0",
    "postgres": "^3.4.5",
    "types": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "typescript": "^6.0.0"
